generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int         @id @default(autoincrement())
  email     String      @unique
  name      String?
  password  String
  quizzes   Quiz[]
  lobbies   GameLobby[]
  documents Document[]
  aiQuizChatSessions AiQuizChatSession[]
}

model Document {
  id                 Int            @id @default(autoincrement())
  userId             Int
  fileName           String
  fileUrl            String
  fileSize           Int
  mimeType           String         @default("application/pdf")
  cloudinaryPublicId String?
  status             DocumentStatus @default(UPLOADED)
  createdAt          DateTime       @default(now())

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]
  aiChatMessages AiQuizChatMessage[]
}

model DocumentChunk {
  id         Int                        @id @default(autoincrement())
  documentId Int
  content    String                     @db.Text
  chunkIndex Int
  embedding  Unsupported("vector(768)")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

enum DocumentStatus {
  UPLOADED
  PARSING
  READY
  ERROR
}

model Quiz {
  id          Int         @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  coverUrl    String?
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   Question[]
  lobby       GameLobby[]
  aiChat      AiQuizChatSession[]
}

model Question {
  id        Int     @id @default(autoincrement())
  quizId    Int
  text      String?
  timeLimit Int     @default(20000)
  points    Int     @default(1000)
  imageUrl  String?
  sortOrder Int

  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options Option[]
  answers PlayerAnswer[]

  @@unique([quizId, sortOrder])
}

model AiQuizChatSession {
  id             Int      @id @default(autoincrement())
  quizId         Int
  userId         Int
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())

  quiz     Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiQuizChatMessage[]

  @@unique([quizId, userId])
  @@index([userId])
  @@index([lastActivityAt])
}

model AiQuizChatMessage {
  id        Int               @id @default(autoincrement())
  sessionId Int
  role      AiChatRole
  content   String            @db.Text
  documentId Int?
  generatedCount Int?
  generatedQuestions Json?
  createdAt DateTime          @default(now())

  session  AiQuizChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  document Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
}

enum AiChatRole {
  user
  assistant
}

model Option {
  id         Int     @id @default(autoincrement())
  questionId Int
  text       String?
  isCorrect  Boolean @default(false)
  sortOrder  Int

  question Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  PlayerAnswer[]

  @@unique([questionId, sortOrder])
}

model GameLobby {
  id        Int          @id @default(autoincrement())
  pin       String       @db.Char(6)
  quizId    Int
  hostId    Int
  status    LobbyStatus  @default(CREATED)
  createdAt DateTime     @default(now())
  endedAt   DateTime?
  endReason LobbyEndReason?

  players         GamePlayer[]
  host            User          @relation(fields: [hostId], references: [id])
  quiz            Quiz          @relation(fields: [quizId], references: [id])
  report          GameLobbyReport?
  questionReports GameLobbyQuestionReport[]
  playerReports   GameLobbyPlayerReport[]
}

enum LobbyEndReason {
  COMPLETED
  HOST_DISCONNECT
}

enum LobbyStatus {
  CREATED
  WAITING
  IN_PROGRESS
  CLOSED
}

model GamePlayer {
  id       Int    @id @default(autoincrement())
  nickname String
  points   Int    @default(0)
  lobbyId  Int

  lobby          GameLobby             @relation(fields: [lobbyId], references: [id])
  answers        PlayerAnswer[]
  playerReports  GameLobbyPlayerReport[]

  @@unique([lobbyId, nickname])
}

model PlayerAnswer {
  id         Int     @id @default(autoincrement())
  playerId   Int
  questionId Int
  optionId   Int
  isCorrect  Boolean
  points     Int     @default(0)

  player   GamePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  question Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   Option     @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([playerId, questionId])
}

model GameLobbyReport {
  id          Int      @id @default(autoincrement())
  lobbyId     Int      @unique
  totalPlayers Int
  totalQuestions Int
  totalAnswers   Int
  totalCorrect   Int
  totalIncorrect Int
  avgAccuracy    Float
  leaderboardJson Json
  createdAt   DateTime @default(now())

  lobby       GameLobby                @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  questionReports GameLobbyQuestionReport[]
  playerReports   GameLobbyPlayerReport[]

  @@index([lobbyId])
}

model GameLobbyQuestionReport {
  id         Int     @id @default(autoincrement())
  lobbyId    Int
  reportId   Int
  questionId Int
  sortIndex  Int
  correctCount Int
  incorrectCount Int
  correctRate   Float
  optionCountsJson Json

  report   GameLobbyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  lobby    GameLobby       @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([reportId, questionId])
  @@index([lobbyId])
}

model GameLobbyPlayerReport {
  id          Int      @id @default(autoincrement())
  lobbyId     Int
  reportId    Int
  playerId    Int
  nickname    String
  answeredCount Int
  correctCount  Int
  accuracy     Float
  finalScore   Int

  report GameLobbyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  lobby  GameLobby      @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  player GamePlayer     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([reportId, playerId])
  @@index([lobbyId])
}
