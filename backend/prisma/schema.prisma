generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AiChatRole {
  user
  assistant
}

enum DocumentStatus {
  UPLOADED
  PARSING
  READY
  ERROR
}

enum LobbyStatus {
  CREATED
  WAITING
  IN_PROGRESS
  CLOSED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  NUMBER_INPUT
}

enum SaveTargetType {
  QUIZ
  DOCUMENT
}

enum SubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

enum UserRole {
  USER
  ADMIN
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model AiQuizChatMessage {
  id                 Int        @id @default(autoincrement())
  role               AiChatRole
  content            String     @db.Text
  generatedCount     Int?
  generatedQuestions Json?
  createdAt          DateTime   @default(now())

  sessionId  Int
  documentId Int?
  session    AiQuizChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  document   Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
}

model AiQuizChatSession {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())

  quizId   Int
  userId   Int
  quiz     Quiz                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiQuizChatMessage[]

  @@unique([quizId, userId])
  @@index([userId])
  @@index([lastActivityAt])
}

model Document {
  id                 Int            @id @default(autoincrement())
  fileName           String
  fileUrl            String
  fileSize           Int
  mimeType           String         @default("application/pdf")
  cloudinaryPublicId String?
  status             DocumentStatus @default(UPLOADED)
  visibility         Visibility     @default(PRIVATE)
  createdAt          DateTime       @default(now())

  userId         Int
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks         DocumentChunk[]
  aiChatMessages AiQuizChatMessage[]
}

model DocumentChunk {
  id         Int                        @id @default(autoincrement())
  content    String                     @db.Text
  chunkIndex Int
  embedding  Unsupported("vector(768)")

  documentId Int
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model GameLobby {
  id        Int         @id @default(autoincrement())
  pin       String      @db.Char(6)
  status    LobbyStatus @default(CREATED)
  createdAt DateTime    @default(now())
  endedAt   DateTime?

  quizId          Int
  hostId          Int
  players         GamePlayer[]
  host            User                      @relation(fields: [hostId], references: [id])
  quiz            Quiz                      @relation(fields: [quizId], references: [id])
  report          GameLobbyReport?
  questionReports GameLobbyQuestionReport[]
}

model GameLobbyQuestionReport {
  id             Int   @id @default(autoincrement())
  sortIndex      Int
  correctCount   Int
  incorrectCount Int
  correctRate    Float
  breakdownJson  Json?

  lobbyId    Int
  reportId   Int
  questionId Int
  report     GameLobbyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  lobby      GameLobby       @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([reportId, questionId])
  @@index([lobbyId])
}

model GameLobbyReport {
  id              Int      @id @default(autoincrement())
  totalPlayers    Int
  totalQuestions  Int
  totalAnswers    Int
  totalCorrect    Int
  totalIncorrect  Int
  avgAccuracy     Float
  leaderboardJson Json
  createdAt       DateTime @default(now())

  lobbyId         Int                       @unique
  lobby           GameLobby                 @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  questionReports GameLobbyQuestionReport[]

  @@index([lobbyId])
}

model GamePlayer {
  id       Int    @id @default(autoincrement())
  nickname String
  points   Int    @default(0)

  lobbyId Int
  lobby   GameLobby      @relation(fields: [lobbyId], references: [id])
  answers PlayerAnswer[]

  @@unique([lobbyId, nickname])
}

model PlayerAnswer {
  id              Int      @id @default(autoincrement())
  mcSelectedIndex Int?
  textAnswer      String?
  numericAnswer   Decimal? @db.Decimal(18, 6)
  isCorrect       Boolean
  points          Int      @default(0)

  playerId   Int
  questionId Int
  player     GamePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([playerId, questionId])
}

model Quiz {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  coverUrl    String?
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime   @default(now())

  userId    Int
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]
  lobby     GameLobby[]
  aiChat    AiQuizChatSession[]
}

model Question {
  id        Int          @id @default(autoincrement())
  text      String?
  timeLimit Int          @default(20000)
  points    Int          @default(1000)
  imageUrl  String?
  sortOrder Int
  type      QuestionType @default(MULTIPLE_CHOICE)
  data      Json

  quizId  Int
  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers PlayerAnswer[]

  @@unique([quizId, sortOrder])
}

model Save {
  id         Int            @id @default(autoincrement())
  targetType SaveTargetType
  targetId   Int
  createdAt  DateTime       @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([userId, targetType, createdAt])
}

model StripeInvoice {
  id               Int       @id @default(autoincrement())
  stripeInvoiceId  String    @unique
  status           String?
  totalCents       Int?
  amountPaidCents  Int?
  currency         String    @default("usd")
  hostedInvoiceUrl String?
  invoicePdfUrl    String?
  paidAt           DateTime?
  occurredAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([paidAt])
}

model Subscription {
  id                   Int                @id @default(autoincrement())
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  endedAt              DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  userId         Int             @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  name             String?
  avatarUrl        String?
  password         String
  role             UserRole @default(USER)
  isBlocked        Boolean  @default(false)
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())

  aiQuizChatSessions AiQuizChatSession[]
  documents          Document[]
  lobbies            GameLobby[]
  quizzes            Quiz[]
  saves              Save[]
  stripeInvoices     StripeInvoice[]
  subscription       Subscription?
}
